   "source": [
    "# 3513. Number of Unique XOR Triplets I\n",
    "\n",
    "class Solution:\n",
    "    def uniqueXorTriplets(self, nums):\n",
    "        n = len(nums)\n",
    "\n",
    "        if n <= 2:\n",
    "            return n\n",
    "\n",
    "        return 1 << n.bit_length()"
   ]
